{
  "name": "@rankforge/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:seed": "node ../../scripts/run-with-env.mjs tsx src/seed.ts",
    "prisma": "prisma"
  },
  "dependencies": {
    "@prisma/client": "6.19.2",
    "@rankforge/ai": "workspace:*",
    "@rankforge/crawler": "workspace:*",
    "@rankforge/integrations": "workspace:*",
    "@rankforge/seo": "workspace:*",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "eslint": "^9.36.0",
    "prisma": "6.19.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
