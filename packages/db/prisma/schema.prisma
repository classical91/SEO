generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum CrawlRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EffortEstimate {
  LOW
  MEDIUM
  HIGH
}

enum CrawlIssueStatus {
  OPEN
  RESOLVED
  IGNORED
}

enum IssueCategory {
  INDEXABILITY
  METADATA
  CONTENT
  LINKS
  PERFORMANCE
  STRUCTURED_DATA
}

enum RecommendationType {
  PROJECT
  PAGE
}

enum MembershipInviteStatus {
  ACTIVE
  SUSPENDED
}

model User {
  id                   String                    @id @default(cuid())
  name                 String?
  email                String?                   @unique
  emailVerified        DateTime?
  image                String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  accounts             Account[]
  sessions             Session[]
  ownedWorkspaces      Workspace[]               @relation("WorkspaceOwner")
  memberships          Membership[]
  connectedProjects    SearchConsoleConnection[] @relation("SearchConsoleConnectedBy")
  crawlRunsTriggered   CrawlRun[]                @relation("CrawlRunTriggeredBy")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Workspace {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  ownerId     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  owner       User         @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships Membership[]
  projects    Project[]
}

model Membership {
  id          String                 @id @default(cuid())
  workspaceId String
  userId      String
  role        MembershipRole         @default(MEMBER)
  status      MembershipInviteStatus @default(ACTIVE)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  workspace   Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model Project {
  id                      String                   @id @default(cuid())
  workspaceId             String
  name                    String
  slug                    String
  description             String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  workspace               Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  domains                 Domain[]
  crawlRuns               CrawlRun[]
  crawlPages              CrawlPage[]
  crawlLinks              CrawlLink[]
  crawlIssues             CrawlIssue[]
  searchConsoleConnection SearchConsoleConnection?
  searchConsoleMetrics    SearchConsoleMetric[]
  pageSpeedSnapshots      PageSpeedSnapshot[]
  aiRecommendations       AiRecommendation[]

  @@unique([workspaceId, slug])
}

model Domain {
  id            String          @id @default(cuid())
  projectId     String
  hostname      String
  homepageUrl   String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  lastCrawledAt DateTime?
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  crawlRuns     CrawlRun[]
  crawlPages    CrawlPage[]
  crawlIssues   CrawlIssue[]
  robots        RobotsSnapshot[]
  sitemaps      SitemapUrl[]

  @@unique([projectId, hostname])
}

model CrawlRun {
  id              String         @id @default(cuid())
  projectId       String
  domainId        String
  triggeredById   String?
  status          CrawlRunStatus @default(QUEUED)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  errorMessage    String?
  score           Int?
  pagesDiscovered Int            @default(0)
  pagesCrawled    Int            @default(0)
  totalIssues     Int            @default(0)
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  domain          Domain         @relation(fields: [domainId], references: [id], onDelete: Cascade)
  triggeredBy     User?          @relation("CrawlRunTriggeredBy", fields: [triggeredById], references: [id], onDelete: SetNull)
  pages           CrawlPage[]
  links           CrawlLink[]
  issues          CrawlIssue[]
  robots          RobotsSnapshot[]
  sitemaps        SitemapUrl[]
  aiRecommendations AiRecommendation[]
}

model CrawlPage {
  id                  String    @id @default(cuid())
  projectId           String
  domainId            String
  crawlRunId          String
  url                 String
  normalizedUrl       String
  finalUrl            String
  canonicalUrl        String?
  statusCode          Int
  redirectChain       String[]
  title               String?
  metaDescription     String?
  h1                  String?
  metaRobots          String?
  xRobotsTag          String?
  contentType         String?
  wordCount           Int       @default(0)
  schemaCount         Int       @default(0)
  missingAltCount     Int       @default(0)
  internalLinkCount   Int       @default(0)
  htmlBytes           Int       @default(0)
  depth               Int       @default(0)
  isIndexableCandidate Boolean  @default(true)
  discoveredFrom      String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  domain              Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  crawlRun            CrawlRun  @relation(fields: [crawlRunId], references: [id], onDelete: Cascade)
  issues              CrawlIssue[]

  @@unique([crawlRunId, normalizedUrl])
}

model CrawlLink {
  id              String   @id @default(cuid())
  projectId       String
  crawlRunId      String
  fromPageUrl     String
  toUrl           String
  normalizedToUrl String
  anchorText      String?
  isInternal      Boolean  @default(true)
  isBroken        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  crawlRun        CrawlRun @relation(fields: [crawlRunId], references: [id], onDelete: Cascade)
}

model CrawlIssue {
  id           String           @id @default(cuid())
  projectId    String
  domainId     String
  crawlRunId   String
  pageId       String?
  ruleKey      String
  title        String
  summary      String
  category     IssueCategory
  severity     IssueSeverity
  effort       EffortEstimate
  impactScore  Int
  affectedUrl  String
  status       CrawlIssueStatus @default(OPEN)
  detailsJson  Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  domain       Domain           @relation(fields: [domainId], references: [id], onDelete: Cascade)
  crawlRun     CrawlRun         @relation(fields: [crawlRunId], references: [id], onDelete: Cascade)
  page         CrawlPage?       @relation(fields: [pageId], references: [id], onDelete: SetNull)
  aiRecommendations AiRecommendation[]
}

model RobotsSnapshot {
  id         String   @id @default(cuid())
  domainId    String
  crawlRunId  String
  url         String
  raw         String?
  blockedPaths String[]
  sitemaps    String[]
  createdAt   DateTime @default(now())
  domain      Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
  crawlRun    CrawlRun @relation(fields: [crawlRunId], references: [id], onDelete: Cascade)
}

model SitemapUrl {
  id         String   @id @default(cuid())
  domainId   String
  crawlRunId String
  url        String
  source     String
  createdAt  DateTime @default(now())
  domain     Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
  crawlRun   CrawlRun @relation(fields: [crawlRunId], references: [id], onDelete: Cascade)
}

model SearchConsoleConnection {
  id            String    @id @default(cuid())
  projectId      String    @unique
  connectedById  String
  propertyUrl    String
  propertyLabel  String
  propertyPermissionLevel String?
  lastSyncedAt   DateTime?
  lastSyncError  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  connectedBy    User      @relation("SearchConsoleConnectedBy", fields: [connectedById], references: [id], onDelete: Cascade)
}

model SearchConsoleMetric {
  id          String   @id @default(cuid())
  projectId   String
  pageUrl     String
  date        DateTime
  clicks      Int
  impressions Int
  ctr         Float
  position    Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, pageUrl, date])
}

model PageSpeedSnapshot {
  id                 String   @id @default(cuid())
  projectId          String
  pageUrl            String
  strategy           String
  performanceScore   Int
  seoScore           Int
  accessibilityScore Int
  bestPracticesScore Int
  lcpMs              Float?
  inpMs              Float?
  cls                Float?
  rawPayload         Json?
  capturedAt         DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AiRecommendation {
  id              String             @id @default(cuid())
  projectId       String
  crawlRunId      String?
  issueId         String?
  pageUrl         String?
  type            RecommendationType @default(PROJECT)
  title           String
  summary         String
  rationale       String
  actionsJson     Json
  sourceRuleKeys  String[]
  model           String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  project         Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  crawlRun        CrawlRun?          @relation(fields: [crawlRunId], references: [id], onDelete: SetNull)
  issue           CrawlIssue?        @relation(fields: [issueId], references: [id], onDelete: SetNull)
}
