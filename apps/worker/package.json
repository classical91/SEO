{
  "name": "@rankforge/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@rankforge/ai": "workspace:*",
    "@rankforge/crawler": "workspace:*",
    "@rankforge/db": "workspace:*",
    "@rankforge/integrations": "workspace:*",
    "@rankforge/seo": "workspace:*",
    "bullmq": "^5.71.1",
    "dotenv": "^16.6.1",
    "ioredis": "^5.8.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "eslint": "^9.36.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
