{
  "name": "rankforge",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "corepack pnpm -r --if-present run build",
    "dev": "corepack pnpm --parallel --filter @rankforge/web --filter @rankforge/worker run dev",
    "lint": "corepack pnpm -r --if-present run lint",
    "typecheck": "corepack pnpm -r --if-present run typecheck",
    "test": "corepack pnpm -r --if-present run test",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "db:generate": "node scripts/run-with-env.mjs prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate": "node scripts/run-with-env.mjs prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:seed": "node scripts/run-with-env.mjs tsx packages/db/src/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1",
    "globals": "^16.4.0"
  }
}
